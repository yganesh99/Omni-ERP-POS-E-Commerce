NODE_ENV=test
PORT=4001

# MongoDB URI is overridden at runtime by mongodb-memory-server
MONGO_URI=mongodb://127.0.0.1:27017/erp_test

# Test JWT secrets — safe to commit, only used in test mode
JWT_ACCESS_SECRET=test_access_secret_do_not_use_in_production_abcdef1234567890
JWT_REFRESH_SECRET=test_refresh_secret_do_not_use_in_production_abcdef0987654321
ACCESS_TOKEN_EXP=15m
REFRESH_TOKEN_EXP=7d

STOCK_LOCK_TTL_MINUTES=15

# Google OAuth placeholders (not tested in API suite)
GOOGLE_CLIENT_ID=test_google_client_id
GOOGLE_CLIENT_SECRET=test_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:4001/api/auth/google/callback
FRONTEND_URL=http://localhost:3000

CORS_ORIGIN=*
